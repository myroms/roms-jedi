## Data assimilation cycle YAML single observations block:
##
## The 'obsfile' are generated authomatically for the 'obsdatain' and 'obsdataout'
## block in the input YAML templates for a specified cycle time window. It replaces
## the token __OBSERVATIONS__(OBS_OUTPUT_DIR). Currently, the ouput observation
## filenames generated by the UFO/IODA operators are the same as input observation,
## but located at the specified subdirectory OBS_OUTPUT_DIR.

- obs space:
    name: InsituTS
    obsdatain:
      engine:
        type: H5File
        obsfile: __TS_SINGLE_OBS__
    obsdataout:
      engine:
        type: H5File
        obsfile: __OBS_OUTPUT_PATH__/__ROMS_APP___TS___MODEL__.nc4
    simulated variables: [salinity, waterTemperature]
  obs operator:
    name: VertInterp
    vertical coordinate: model_level_depth_at_cell_center
    observation vertical coordinate: depth
    observation alias file: Data/obsop_name_map.yaml
  obs error:
    covariance model: diagonal

