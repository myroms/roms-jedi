# ROMS-JEDI LinearModel Unit Test: __ROMS_APPLICATION__
#
# It includes tests to ROMS NLM, TLM, and ADM kernels.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

AnalisysVariables: &Avars [ssh, uocn, vocn, tocn, socn]

TrajectoryVariables: &Tvars [ssh, u2docn, v2docn,
                             uocn, vocn, tocn, socn,
                             DU_avg1, DV_avg1, DU_avg2, DV_avg2,
                             Ktocn, Ksocn, Kvocn]

ForecastLength: &ForecastLength __TLAD_FORECAST_LENGTH__

model:
  name: ROMS
  model variables: *Tvars
  tstep: __ROMS_TIMESTEP__
  simulation length: *ForecastLength
 
model aux control: null

initial condition:
  date: &date __INITIAL_DATE__
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__
  state variables: *Tvars

background error:
  covariance model: romsjedi-ID
  analysis variables: *Avars
  date: *date
  bump:
    general:
      datadir: Data/bump
      prefix: __ROMS_APP___bump
    drivers:
      strategy: specific_univariate
  correlation:
  - name: ocn
    variables: *Avars

linear model test:
  forecast length: *ForecastLength
  first multiplier TL: 0.01
  iterations TL: 20
  tolerance AD: 1.0
  tolerance TL: 1.0
  tolerance zero length forecast: 1e+2         # Since initial increment is modified (see NOTES)

linear model:
  name: LMROMS
  date: *date
  tstep: __ROMS_TIMESTEP__
  simulation length: *ForecastLength
  lm variables: *Avars
  trajectory:
    model variables: *Tvars

model aux control: null

analysis variables: *Avars


# NOTES:
#
#   In the initialization phase, the ROMS TLM and ADM kernels
#   computes vertically integrated momentum and applies lateral
#   boundary conditions to the OOPS initial increment vector in
#   preparation for time stepping. The value specified in
#   'tolerance zero length forecast' is utilized in the zero-length
#   unit test, which involves calling the 'initialize' and
#   'finalize' routines and comparing the norms of the analysis
#   vector (Avars).
