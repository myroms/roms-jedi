# ROMS-JEDI LinearModel Unit Test: __ROMS_APPLICATION__
#
# It includes tests to ROMS NLM, TLM, and ADM kernels.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

AnalisysVariables: &avars [ssh, uocn, vocn, tocn, socn]

TrajectoryVariables: &tvars [ssh, u2docn, v2docn,
                             uocn, vocn, tocn, socn,
                             DU_avg1, DV_avg1, DU_avg2, DV_avg2,
                             Ktocn, Ksocn, Kvocn]

ForecastLength: &ForecastLength __TLAD_FORECAST_LENGTH__

model:
  name: ROMS
  model variables: *tvars
  tstep: __ROMS_TIMESTEP__
  simulation length: *ForecastLength
 
model aux control: null

initial condition:
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__
  date: &date __INITIAL_DATE__
  state variables: *tvars

background error:
  covariance model: romsjedi-ID
  analysis variables: *avars
  date: *date
  bump:
    general:
      datadir: Data/bump
      prefix: __ROMS_APP___bump
    drivers:
      strategy: specific_univariate
  correlation:
  - name: ocn
    variables: *avars

linear model test:
  forecast length: *ForecastLength
  first multiplier TL: 0.01
  iterations TL: 20
# tolerance AD: 1.0e-6
  tolerance AD: 1.0e-2                         # we have to remove iNLM kernel call to "ROMS_deallocate_arrays"
# tolerance AD: 10                             # We need to figure out the dot product high error
  tolerance TL: 1.0

linear model:
  name: LMROMS
  date: *date
  tstep: __ROMS_TIMESTEP__
  simulation length: *ForecastLength
  lm variables: *avars
  trajectory:
    model variables: *tvars

analysis variables: *avars


# NOTES:
#
# * Due to ROMS exact discrete adjoint and complex high-order,
#   multiple levels, predictor/corrector time-stepping scheme,
#   there are several technical issues in ingesting the incoming
#   increment back to ROMS kernels.  Usually, the incoming
#   increment is the modified previous timestep state solution.
#   It is expected to use this modified state to advance the
#   solution for the next timestep. But, of course, it will spoil
#   ROMS predictor/corrector, multiple time level stepping. So,
#   we need to figure out how to use such a previous state as a
#   forcing term without affecting the time stepping.
#
# * In addition, ROMS modifies the initial increment generated by
#   OOPS by applying lateral boundary conditions and computing the
#   vertically integrated (barotropic) momentum components for the
#   split, fast-dynamics shallow-water equations. However, we haven't
#   figured out how to pass the updated initial increment back to
#   OOPS in the current design.
#
# * Currently, the "testLinearModelAdjoint" when comparing initial
#   and final dot products with lower tolerance values. We are
#   investigating why this is the case.  Outside of OOPS, ROMS
#   passes that dot product with much smaller tolerance:
#
#     Initial Dot product, dot0 = -370.2587
#     Final   Dot product, dot1 = -370.2587
#         Difference, dot0-dot1 = -3.19e-05
