# ROMS-JEDI LinearModel Unit Test: __ROMS_APPLICATION__
#
# It includes tests to ROMS NLM, TLM, and ADM kernels.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

ForecastLength: &ForecastLength __TLAD_FORECAST_LENGTH__

roms analysis: &roms_analysis
- sea_surface_height_above_geoid
- sea_water_x_velocity                                              # C-grid
- sea_water_y_velocity                                              # C-grid
- sea_water_temperature
- sea_water_salinity

roms state: &roms_state
- sea_surface_height_above_geoid
- eastward_sea_water_velocity                                       # A-grid
- northward_sea_water_velocity                                      # A-grid
- sea_water_x_velocity                                              # C-grid
- sea_water_y_velocity                                              # C-grid
- sea_water_temperature
- sea_water_salinity
- model_level_depth_at_cell_center
- barotropic_sea_water_x_velocity
- barotropic_sea_water_y_velocity
- sea_water_time_average_of_barotropic_x_velocity_flux
- sea_water_time_average_of_barotropic_y_velocity_flux
- sea_water_correct_barotropic_x_velocity_flux_for_coupling
- sea_water_correct_barotropic_y_velocity_flux_for_coupling
- vertical_viscosity_coefficient_of_sea_water
- vertical_diffusion_coefficient_of_temperature_in_sea_water
- vertical_diffusion_coefficient_of_salinity_in_sea_water

model:
  name: ROMS
  tstep: &TimeStep __ROMS_TIMESTEP__
  simulation length: *ForecastLength
  model variables: *roms_state

model aux control: null

initial condition:
  date: &date __INITIAL_DATE__
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__
  state variables: *roms_state

background error:
  covariance model: romsjedi-ID
  analysis variables: *roms_analysis
  date: *date
  bump:
    general:
      datadir: Data/bump
      prefix: __ROMS_APP___bump
    drivers:
      strategy: specific_univariate
  correlation:
  - name: ocn
    variables: *roms_analysis

linear model test:
  forecast length: *ForecastLength
  first multiplier TL: 0.01
  iterations TL: 20
  tolerance AD: 1.0
  tolerance TL: 1.0
  tolerance zero length forecast: 1e+2         # Since initial increment is modified (see NOTES)

linear model:
  name: LMROMS
  date: *date
  tstep: *TimeStep
  simulation length: *ForecastLength
  lm variables: *roms_analysis
  trajectory:
    model variables: *roms_state
    tstep: *TimeStep

model aux control: null

analysis variables: *roms_analysis


# NOTES:
#
#   In the initialization phase, the ROMS TLM and ADM kernels
#   computes vertically integrated momentum and applies lateral
#   boundary conditions to the OOPS initial increment vector in
#   preparation for time stepping. The value specified in
#   'tolerance zero length forecast' is utilized in the zero-length
#   unit test, which involves calling the 'initialize' and
#   'finalize' routines and comparing the norms of the analysis
#   vector (roms_analysis).
