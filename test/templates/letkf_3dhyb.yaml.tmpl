# ROMS-JEDI LETKF-Mean/Hybrid 3DEnVar FGAT (Dual Formulation) Test: __ROMS_APPLICATION__
#
# It uses the analysis mean from LETKF as the background for
# Hybrid 3DEnVar, and the LETKF analysis ensemble for the ensemble
# error covariance modeling.
# Reference: Penny, S.G, MWR, 142: 2139-2149 (2014).
#
# It uses ROMS 3D state vector and the 4D-Var cost function for a
# 3D-FGAT (First Guess at Appropriate Time) by approximating the
# Tangent Linear and Adjoint models with the Identity operator.
# It computes the analysis increment for the initial state vector
# (beginning of the DA window).
#
# Using RPCG (Augmented Restricted Preconditioned Conjugate Gradient)
# Minimizer, Gratton and Tshimanga, QJRMS, 135: 1573-1585 (2009).

forecast length: &ForecastLength __FORECAST_LENGTH__

model timestep:  &TimeStep __ROMS_TIMESTEP__

initial date: &date __INITIAL_DATE__

roms analysis: &roms_analysis
- sea_surface_height_above_geoid
- eastward_sea_water_velocity                      # A-grid
- northward_sea_water_velocity                     # A-grid
- sea_water_temperature
- sea_water_salinity

roms state: &roms_state
- sea_surface_height_above_geoid
- eastward_sea_water_velocity                      # A-grid
- northward_sea_water_velocity                     # A-grid
- sea_water_x_velocity                             # C-grid
- sea_water_y_velocity                             # C-grid
- sea_water_temperature
- sea_water_salinity
- model_level_depth_at_cell_center
- vertical_diffusion_coefficient_of_temperature_in_sea_water
- vertical_diffusion_coefficient_of_salinity_in_sea_water
- vertical_viscosity_coefficient_of_sea_water

cost function:
  cost type: 4D-Var
  time window:
    begin: *date
    length: *ForecastLength
  analysis variables: *roms_analysis

  geometry: &geom
    project_dir: __PROJECT_DIR__
    roms_stdinp: __ROMS_STDINP__
    fields metadata: Data/fields_metadata.yaml
    ng: 1                                          # ROMS nested grid number

  model:
    name: NLROMS
    model variables: *roms_state
    simulation length: *ForecastLength
    tstep: *TimeStep

  background:                                      # LETKF analysis mean
    fields_dir: Data/letkf/solver
    fields_filename: __ROMS_APP___roms_letkf_mem000___INI_DATETIME__.nc
    fields_record: __INI_PRIOR_RECORD__
    state variables: *roms_state
    date: *date

  background error:
    covariance model: hybrid
    components:
    - covariance:                                  # Static error covariance
        covariance model: SABER
        saber central block:
          saber block name: BUMP_NICAS
          active variables: *roms_analysis
          fields metadata:
            sea_surface_height_above_geoid:
              vert_coord: vert_coord_2d
          read:
            drivers:
              multivariate strategy: univariate
              read global nicas: false
              read local nicas: true
            model:
              level for 2d variables: last
              do not cross mask boundaries: true
            nicas:
              interpolation in global file: false
            io:
              data directory: Data/bump
              files prefix: __ROMS_APP___bump_cor
            grids:
            - model:
                variables:
                - sea_surface_height_above_geoid
            - model:
                variables:
                - eastward_sea_water_velocity
                - northward_sea_water_velocity
                - sea_water_temperature
                - sea_water_salinity

        saber outer blocks:
        - saber block name: StdDev
          read:
            model file:
              fields_dir: __FIELDS_DIR__
              fields_filename: __ROMS_PRIOR_STD__
              fields_record: 1
              state variables: *roms_analysis
              date: *date
      weight:                                      # Static B weight
        value: __STATIC_B_WEIGHT__

    - covariance:
        covariance model: ensemble                 # Ensemble error covariance
        localization:
          localization method: SABER
          saber central block:
            saber block name: BUMP_NICAS
            active variables: *roms_analysis
            fields metadata:
              sea_surface_height_above_geoid:
                vert_coord: vert_coord_2d
            read:
              drivers:
                multivariate strategy: duplicated
                read global nicas: false
                read local nicas: true
              model:
                level for 2d variables: last
                do not cross mask boundaries: true
              nicas:
                interpolation in global file: false
              io:
                data directory: Data/bump_loc
                files prefix: __ROMS_APP___bump_loc
        members from template:
          template:
            date: *date
            fields_dir: Data/ensembles
            fields_filename: __ROMS_APP___roms_ensemble_mem%mem%___INI_DATETIME__.nc
#           fields_dir: Data/letkf/solver
#           fields_filename: __ROMS_APP___roms_letkf_mem%mem%___INI_DATETIME__.nc
            fields_record: __INI_PRIOR_RECORD__
            state variables: *roms_state
          pattern: %mem%
          nmembers: __NMEMBERS__
          zero padding: 3
      weight:                                    # Ensemble B weight
        value: __ENSEMBLE_WEIGHT__

  observations:
    obs perturbations: false                     # default
    observers:

    - obs space:
        name: InsituTemperature
        obsdatain:
          engine:
            type: H5File
            obsfile: __TEMPERATURE_OBS__
        obsdataout:
          engine:
            type: H5File
            obsfile: Data/letkf/3dhyb/__ROMS_APP___temp_letkf_3dhyb.nc4
        simulated variables: [waterTemperature]
      obs operator:
        name: VertInterp
        vertical coordinate: model_level_depth_at_cell_center
        observation vertical coordinate: depth
        observation alias file: Data/obsop_name_map.yaml
      obs error:
        covariance model: diagonal

    - obs space:
        name: InsituSalinity
        obsdatain:
          engine:
            type: H5File
            obsfile: __SALINITY_OBS__
        obsdataout:
         engine:
            type: H5File
            obsfile: Data/letkf/3dhyb/__ROMS_APP___salt_letkf_3dhyb.nc4
        simulated variables: [salinity]
      obs operator:
        name: VertInterp
        vertical coordinate: model_level_depth_at_cell_center
        observation vertical coordinate: depth
        observation alias file: Data/obsop_name_map.yaml
      obs error:
        covariance model: diagonal

    - obs space:
        name: SST
        obsdatain:
          engine:
            type: H5File
            obsfile: __SST_OBS__
        obsdataout:
          engine:
            type: H5File
            obsfile: Data/letkf/3dhyb/__ROMS_APP___sst_letkf_3dhyb.nc4
        simulated variables: [seaSurfaceTemperature]
      obs operator:
        name: Identity
        observation alias file: Data/obsop_name_map.yaml
      obs error:
        covariance model: diagonal

    - obs space:
        name: ADT
        obsdatain:
          engine:
            type: H5File
            obsfile: __ADT_OBS__
        obsdataout:
          engine:
            type: H5File
            obsfile: Data/letkf/3dhyb/__ROMS_APP___adt_letkf_3dhyb.nc4
        simulated variables: [absoluteDynamicTopography]
      obs operator:
        name: ADT
      obs error:
        covariance model: diagonal

variational:
  minimizer:
    algorithm: RPCG                                # Dual Formulation
  iterations:                                      # each item defines an outer loop
  - geometry: *geom
    linear model:
      name: Identity                               # Identity TLM/ADM
      increment variables: *roms_analysis
      tstep: *TimeStep
    ninner: 10
    gradient norm reduction: 1E-10
    test: on
    diagnostics:                                   # Written into output IODA files
      departures: ombg                             # OBS - H(Xb)
    online diagnostics:
      write increment: true
      increment:                                   # DA increment output file
        state component:
          add_varchange: true                      # Add fields from variable change
          single_record: true
          data_dir: Data/letkf/3dhyb
          prefix: __ROMS_APP___roms
          exp: 3dhyb
          type: inc
          date: *date

final:                                             # Written into output IODA files
  diagnostics:
    departures: oman                               # saving OBS - H(Xa) in output file

output:
  file_policy: __OUTPUT_FILE_POLICY__
  frequency: &frequency __OUTPUT_FREQUENCY__
  data_frequency: *frequency
  data_dir: Data/letkf/3dhyb
  prefix: __ROMS_APP___roms
  exp: letkf_3dhyb
  type: nlm
  date: *date

test:
  reference filename: testref/letkf_3dhyb.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/letkf_3dhyb.log
  test output filename: testoutput/letkf_3dhyb.out
