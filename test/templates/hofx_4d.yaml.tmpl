# ROMS-JEDI 4D HofX Unit Test: __ROMS_APPLICATION__

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

forecast length: &ForecastLength __FORECAST_LENGTH__

model:
  name: NLROMS
  tstep: __ROMS_TIMESTEP__
  simulation length: *ForecastLength

  model variables:
  - sea_surface_height_above_geoid
  - eastward_sea_water_velocity                # A-grid
  - northward_sea_water_velocity               # A-grid
  - sea_water_x_velocity                       # C-grid
  - sea_water_y_velocity                       # C-grid
  - sea_water_temperature
  - sea_water_salinity
  - vertical_diffusion_coefficient_of_temperature_in_sea_water
  - vertical_diffusion_coefficient_of_salinity_in_sea_water
  - vertical_viscosity_coefficient_of_sea_water

initial condition:
  date: __INITIAL_DATE__
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__

  state variables:
  - sea_surface_height_above_geoid
  - eastward_sea_water_velocity                # A-grid
  - northward_sea_water_velocity               # A-grid
  - sea_water_x_velocity                       # C-grid
  - sea_water_y_velocity                       # C-grid
  - sea_water_temperature
  - sea_water_salinity
  - model_level_depth_at_cell_center

time window:
  begin: __INITIAL_DATE__
  length: *ForecastLength

observations:
  observers:

  __OBSERVATION_DATA__

test:
  reference filename: testref/hofx_4d.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/hofx_4d.log
  test output filename: testoutput/hofx_4d.out

# NOTES:
#
# * Check IODA ObsSpace YAML file for metadata naming conventions:
#
#   JCSDA repository: ioda/share/ioda/yaml/validation/ObsSpace.yaml
#   https://github.com/JCSDA-internal/ioda/blob/develop/share/ioda/yaml/validation/ObsSpace.yaml
