# ROMS-JEDI BUMP_NICAS Covariance Unit Test: __ROMS_APPLICATION__
#
# Currently, BUMP and ATLAS does not support staggered grids. Thus, the Error
# Covariance convolutions is limited to RHO-points.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                               # ROMS nested grid number

background:
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__   
  fields_record: __INI_PRIOR_RECORD__
  state variables: [ssh, tocn, socn]
  date: &date __INITIAL_DATE__

background error:
  covariance model: SABER
  saber central block:
    saber block name: BUMP_NICAS
    active variables: &rho_vars [ssh, tocn, socn]
    calibration:
      io:
        data directory: Data/bump
        files prefix: __ROMS_APP___bump_cov
      drivers:
        multivariate strategy: univariate             # NICAS multivariate strategy
        compute nicas: true                           # Run NICAS driver
        write local nicas: true
      model:
        do not cross mask boundaries: true
      nicas:
        resolution: 6.0                               # NICAS subgrid resolution
        explicit length-scales: true
        horizontal length-scale:
        - groups:
          - ssh
          value: __STATIC_B_HCORRELATION_SSH__
        - groups:
          - tocn
          value: __STATIC_B_HCORRELATION_TOCN__
        - groups:
          - socn
          value: __STATIC_B_HCORRELATION_SOCN__
        vertical length-scale:
        - groups:
          - tocn
          value: __STATIC_B_VCORRELATION_TOCN__
        - groups:
          - socn
          value: __STATIC_B_HCORRELATION_SOCN__
      grids:
      - model:
          variables:
          - ssh
      - model:
          variables:
          - tocn
          - socn

      output model files:                             # Write horizontal correlations NetCDF file
      - parameter: cor_rh
        file:
          single_record: true
          data_dir: Data/bump
          prefix: __ROMS_APP__
          exp: bump
          type: cov_rh
          date: *date
      - parameter: cor_rv                             # Write vertical correlations NetCDF file
        file:
          single_record: true
          data_dir: Data/bump
          prefix: __ROMS_APP__
          exp: bump
          type: cov_rv
          date: *date

test:
  reference filename: testref/parameters_bump_cov_nicas.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/parameters_bump_cov_nicas.log
  test output filename: testoutput/parameters_bump_cov_nicas.out
