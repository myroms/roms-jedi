# ROMS-JEDI Ensemble Perturbation Test: __ROMS_APPLICATION__
#
# It generates Ensemble Perturbations initial conditions and 
# run ROMS for the specified time. The ensemble members
# have the suffix pattern %mem% ("_men001", ..., "_memXXX") in
# their output history files.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

forecast length: &ForecastLength __FORECAST_LENGTH__

members: __MEMBERS__

perturbed variables: [ssh, tocn, socn]

model:
  name: ROMS
  model variables: &roms_state [ssh, uocn, vocn, tocn, socn]
  tstep: __ROMS_TIMESTEP__
  simulation length: *ForecastLength

initial condition:
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__
  state variables: *roms_state
  date: &date __INITIAL_DATE__

background error:
  covariance model: SABER
  saber central block:
    saber block name: BUMP_NICAS
    read:
      drivers:
        multivariate strategy: univariate
        read local nicas: true
      io:
        data directory: Data/bump
        files prefix: __ROMS_APP___bump_cor
      grids:
      - model:
          variables:
          - ssh
      - model:
          variables:
          - tocn
          - socn
  saber outer blocks:
  - saber block name: StdDev
    read:
      model file:
        fields_dir: __FIELDS_DIR__
        fields_filename: __ROMS_PRIOR_STD__
        fields_record: 1
        state variables: *roms_state
        date: *date

# Output filenames are: " __ROMS_APP___roms_ensemble_memXXX_YYYY-MM-DD-hh.mm.ss.nc"

output:
  file_policy: __OUTPUT_FILE_POLICY__
  frequency: &frequency __OUTPUT_FREQUENCY__
  data_frequency: *frequency
  data_dir: Data/ensembles
  prefix: __ROMS_APP___roms
  exp: ensemble
  type: mem
  date: *date
  forecast length: *ForecastLength

test:
  reference filename: testref/ens_perturbation.ref
  float relative tolerance: 1.0e-1
  log output filename: testoutput/ens_perturbation.log
  test output filename: testoutput/ens_perturbation.out
