# ROMS-JEDI Ensemble Mean Variance Test: __ROMS_APPLICATION__

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

ensemble:
  members from template:
    template:
      date: &date __INITIAL_DATE__
      fields_dir: Data/ensembles
      fields_filename: __ROMS_APP___roms_ensemble_mem%mem%___INI_DATETIME__.nc
      fields_record: __INI_PRIOR_RECORD__
      state variables: &roms_state
      - sea_surface_height_above_geoid
      - eastward_sea_water_velocity            # A-grid
      - northward_sea_water_velocity           # A-grid
      - sea_water_x_velocity                   # C-grid
      - sea_water_y_velocity                   # C-grid
      - sea_water_temperature
      - sea_water_salinity
    pattern: %mem%
    nmembers: __NMEMBERS__
    zero padding: 3

variance output:
  single_record: true
  data_dir: Data/ensembles
  prefix: __ROMS_APP___roms
  exp: ensemble
  type: variance
  date: *date

standard deviation output:
  single_record: true
  data_dir: Data/ensembles
  prefix: __ROMS_APP___roms
  exp: ensemble
  type: stddev
  date: *date

mean output:
  single_record: true
  data_dir: Data/ensembles
  prefix: __ROMS_APP___roms
  exp: ensemble
  type: mean
  date: *date

test:
  reference filename: testref/ens_meanandvariance.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/ens_meanandvariance.log
  test output filename: testoutput/ens_meanandvariance.out