# ROMS-JEDI LETKF Split Observer Test: __ROMS_APPLICATION__

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                          # ROMS nested grid number

time window:
  begin:  &date 2004-01-03T00:00:00Z
  length: &ForecastLength PT96H

increment variables: &roms_analysis [ssh, uocn, vocn, tocn, socn]

_obs distribution: &ObsSpaceDistribution
  name: Halo
  halo size: __OBS_DISTRIBUTION__

_hor obs localization: &HorizontalObsLoc
  localization method: Horizontal Gaspari-Cohn
# localization method: Heaviside
  lengthscale: __LOCALIZATION_HCORRELATION__

_conventional vertical localization: &DepthVertObsLoc
  localization method: Vertical localization
  vertical lengthscale: __LOCALIZATION_VCORRELATION__
  ioda vertical coordinate: depth
  ioda vertical coordinate group: MetaData
  localization function: Gaspari Cohn

background:
  members from template:
    template:
      date: *date
      fields_dir: Data/ensembles
      fields_filename: __ROMS_APP___roms_ensemble_mem%mem%___INI_DATETIME__.nc
      fields_record: __INI_PRIOR_RECORD__
      state variables: &roms_state [ssh, uocn, vocn, tocn, socn, zocn_r]
    pattern: %mem%
    nmembers: __NMEMBERS__
    zero padding: 3

observations:
  obs perturbations: false                       # default
  observers:

# - obs space:
#     name: InsituTemperature
#     distribution: *ObsSpaceDistribution
#     obsdatain:
#       engine:
#         type: H5File
#         obsfile: __TEMPERATURE_OBS__
#     obsdataout:
#       engine:
#         type: H5File
#         obsfile: Data/letkf/split_observer/__ROMS_APP___temp_letkf_split_observer.nc4
#     simulated variables: [waterTemperature]
#   obs operator:
#     name: VertInterp
#     vertical coordinate: model_level_depth_at_cell_center
#     observation vertical coordinate: depth
#     observation alias file: testinput/obsop_name_map.yaml
#   obs error:
#     covariance model: diagonal
#   obs localizations:
#   - <<: *HorizontalObsLoc
#   - <<: *DepthVertObsLoc

# - obs space:
#     name: InsituSalinity
#     distribution: *ObsSpaceDistribution
#     obsdatain:
#       engine:
#         type: H5File
#         obsfile: __SALINITY_OBS__
#     obsdataout:
#       engine:
#         type: H5File
#     obsdataout:
#       engine:
#         type: H5File
#         obsfile: Data/letkf/split_observer/__ROMS_APP___salt_letkf_split_observer.nc4
#     simulated variables: [salinity]
#   obs operator:
#     name: VertInterp
#     vertical coordinate: model_level_depth_at_cell_center
#   observation vertical coordinate: depth
#     observation alias file: testinput/obsop_name_map.yaml
#   obs error:
#     covariance model: diagonal
#   obs localizations:
#   - <<: *HorizontalObsLoc
#   - <<: *DepthVertObsLoc
 
  - obs space:
      name: SST 
      distribution: *ObsSpaceDistribution
      obsdatain:
        engine:
          type: H5File
          obsfile: __SST_OBS__
      obsdataout:
        engine:
          type: H5File
          obsfile: Data/letkf/split_observer/__ROMS_APP___sst_letkf_split_observer.nc4
      simulated variables: [seaSurfaceTemperature]
    obs operator:
      name: Identity
      observation alias file: testinput/obsop_name_map.yaml
    obs error:
      covariance model: diagonal
    obs localizations:
    - <<: *HorizontalObsLoc

  - obs space:
      name: ADT
     distribution: *ObsSpaceDistribution
      obsdatain:
        engine:
          type: H5File
          obsfile: __ADT_OBS__
      obsdataout:
        engine:
          type: H5File
          obsfile: Data/letkf/split_observer/__ROMS_APP___adt_letkf_split_observer.nc4
      simulated variables: [absoluteDynamicTopography]
    obs operator:
      name: ADT
    obs error:
      covariance model: diagonal
    obs localizations:
    - <<: *HorizontalObsLoc

driver:
  run as observer only: true
  update obs config with geometry info: false

local ensemble DA:
  solver: LETKF

output:
  single_record: true
  data_dir: Data/letkf/split_observer
  prefix: __ROMS_APP___roms
  exp: letkf
  type: mem
  date: *date

test:
  reference filename: testref/letkf_split_observer.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/letkf_split_observer.log
  test output filename: testoutput/letkf_split_observer.out
