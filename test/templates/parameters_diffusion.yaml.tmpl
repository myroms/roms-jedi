# ROMS-JEDI SABER Pseudo-Diffusion Training Parameters (diffusion) Test: __ROMS_APPLICATION__
#
# It sets correlation parameters to model the background error covariance
# using SABER diffusion operator.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                               # ROMS nested grid number

background:
  date: &date __INITIAL_DATE__
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__

  state variables: &roms_state
  - sea_surface_height_above_geoid
  - eastward_sea_water_velocity                       # A-grid
  - northward_sea_water_velocity                      # A-grid
  - sea_water_x_velocity                              # C-grid
  - sea_water_y_velocity                              # C-grid
  - sea_water_temperature
  - sea_water_salinity

# In SABER, by default, all the length scales are defined as the half-witdh
# Gaspari-Cohn (1999) support radius, c/2. The relationship with the Daley (1991)
# correlation Gaussian length, L, is:  L = SQRT(0.3) * c/2   and
#                                      c = 2 * L / SQRT(0.3)
# The diffusion operator is defined in terms of L.

background error:
  covariance model: SABER
  saber central block:
    saber block name: diffusion

    active variables: &roms_analysis
    - sea_surface_height_above_geoid
    - eastward_sea_water_velocity                     # A-grid
    - northward_sea_water_velocity                    # A-grid
    - sea_water_x_velocity                            # C-grid
    - sea_water_y_velocity                            # C-grid
    - sea_water_temperature
    - sea_water_salinity

    fields metadata:
      sea_surface_height_above_geoid:
        vert_coord: vert_coord_2d

    calibration:
      normalization:
        iterations: 30000                             # Randomization approach
      groups:
      - horizontal:
          as gaussian: true
          fixed value: __SSH_HCOR__
          mask: "mask_rho"
          model variable: sea_surface_height_above_geoid
        write:
          filepath: __PATH_SSH_HCOR__

      - horizontal:
          as gaussian: true
          fixed value: __UVEL_HCOR__
          mask: "mask_rho"
          model variable: eastward_sea_water_velocity
        write:
          filepath: __PATH_UVEL_HCOR__

      - horizontal:
          as gaussian: true
          fixed value: __VVEL_HCOR__
          mask: "mask_rho"
          model variable: northward_sea_water_velocity
        write:
          filepath: __PATH_VVEL_HCOR__

      - horizontal:
          as gaussian: true
          fixed value: __TEMP_HCOR__
          mask: "mask_rho"
          model variable: sea_water_temperature
        write:
          filepath: __PATH_TEMP_HCOR__

      - horizontal:
          as gaussian: true
          fixed value: __SALT_HCOR__
          mask: "mask_rho"
          model variable: sea_water_salinity
        write:
          filepath: __PATH_SALT_HCOR__

      - vertical:
          as gaussian: true
          fixed value: __UVEL_VCOR__
          levels: __NLEVELS__
          mask: "mask_rho"
          model variable: eastward_sea_water_velocity
        write:
          filepath: __PATH_UVEL_VCOR__

      - vertical:
          as gaussian: true
          fixed value: __VVEL_VCOR__
          levels: __NLEVELS__
          mask: "mask_rho"
          model variable: northward_sea_water_velocity
        write:
          filepath: __PATH_VVEL_VCOR__

      - vertical:
          as gaussian: true
          fixed value: __TEMP_VCOR__
          levels: __NLEVELS__
          mask: "mask_rho"
          model variable: sea_water_temperature
        write:
          filepath: __PATH_TEMP_VCOR__

      - vertical:
          as gaussian: true
          fixed value: __SALT_VCOR__
          levels: __NLEVELS__
          mask: "mask_rho"
          model variable: sea_water_salinity
        write:
          filepath: __PATH_SALT_VCOR__
