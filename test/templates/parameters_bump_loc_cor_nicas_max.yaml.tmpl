# ROMS-JEDI BUMP Localization Training Parameters (BUMP_NICAS) Test: __ROMS_APPLICATION__
#
# It sets correlation parameters to model the ensemble background error
# covariance localization using BUMP/NICAS.
#
# Notice that BUMP uses ATLAS which only supports the computations at the
# center of grid cell (ROMS's RHO-points). We need to figure out what to do
# for the staggered U- and V-points state variables later.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP_MAX__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                           # ROMS nested grid number
  vertical coordinate: depths                     # ATLAS FunctionSpace default
# vertical coordinate: levels                     # ATLAS FunctionSpace levels

background:
  date: &date __INITIAL_DATE__
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__

  state variables: &roms_state
  - sea_surface_height_above_geoid
  - sea_water_x_velocity                              # C-grid
  - sea_water_y_velocity                              # C-grid
  - sea_water_temperature
  - sea_water_salinity

# In SABER, by default, all the length scales are defined as the half-witdh
# Gaspari-Cohn (1999) support radius, c. The relationship with the Daley (1991)
# correlation Gaussian length, L, is:  L = 2 * c * SQRT(0.3) and
#                                      c = 0.5 * L / SQRT(0.3)

background error:
  covariance model: SABER
  saber central block:
    saber block name: BUMP_NICAS

    active variables: &roms_analysis
    - sea_surface_height_above_geoid
    - sea_water_temperature
    - sea_water_salinity

    fields metadata:
      sea_surface_height_above_geoid:
        vert_coord: vert_coord_2d

    calibration:
      io:
        data directory: Data/bump_loc                 # BUMP localization data directory
        files prefix: __ROMS_APP___bump_loc_max
      drivers:
        multivariate strategy: duplicated             # NICAS multivariate strategy
        compute nicas: true                           # Run NICAS driver
        write diagnostics: true
        write global nicas: false
        write local nicas: true
      model:
        level for 2d variables: last
        do not cross mask boundaries: true
      nicas:
        interpolation in global file: false
#       resolution: 6.0                               # NICAS subgrid resolution
        resolution: 10.0                              # NICAS subgrid resolution (smoother)
        explicit length-scales: true
        horizontal length-scale:
        - groups:
          - common
          value: __LOCALIZATION_HCORRELATION__
        vertical length-scale:
        - groups:
          - common
          value: __LOCALIZATION_VCORRELATION__
      grids:
      - model:
          variables:
          - sea_surface_height_above_geoid
          - sea_water_temperature
          - sea_water_salinity

test:
  reference filename: testref/parameters_bump_loc_cor_nicas_max.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/parameters_bump_loc_cor_nicas_max.log
  test output filename: testoutput/parameters_bump_loc_cor_nicas_max.out
