# ROMS-JEDI Increment Unit Test: __ROMS_APPLICATION__
#
# The increment fields in the Unit Test are initialized with zero or random values.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

inc variables:
- sea_surface_height_above_geoid
- sea_water_temperature
- sea_water_salinity

increment test:
  date: __INITIAL_DATE__
  skip atlas: 1
  skip boundaries: false                       # random field initialization
  dirac:
    ifdir:                                     # State field to perturb
    - sea_surface_height_above_geoid
    ixdir:                                     # field X-index impulse location
    - 25
    iydir:                                     # field Y-index impulse location
    - 20
    izdir:                                     # field Z-index impulse location
    - 1

test atlas interface: false                    # because all variables must be on A-grid

test:
  reference filename: testref/increment.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/increment.log
  test output filename: testoutput/increment.out
