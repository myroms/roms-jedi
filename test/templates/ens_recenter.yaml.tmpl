# ROMS-JEDI Recentered Ensemble Test: __ROMS_APPLICATION__
#
# Recenters ensemble around central state.

geometry:
  project_dir: __PROJECT_DIR__
  roms_stdinp: __ROMS_STDINP__
  fields metadata: Data/fields_metadata.yaml
  ng: 1                                        # ROMS nested grid number

recenter variables: &roms_state [ssh, uocn, vocn, tocn, socn]

center:                                        # Central state
  fields_dir: __FIELDS_DIR__
  fields_filename: __ROMS_INI_PRIOR__
  fields_record: __INI_PRIOR_RECORD__
  state variables: *roms_state
  date: &date __INITIAL_DATE__

zero center: false

ensemble:                                      # Ensembles to be recentered
  members from template:
    template:
      date: *date
      fields_dir: Data/ensembles
      fields_filename: __ROMS_APP___roms_ensemble_mem%mem%___INI_DATETIME__.nc
      fields_record: __INI_PRIOR_RECORD__
      state variables: *roms_state
    pattern: %mem%
    nmembers: __NMEMBERS__
    zero padding: 3

ensemble meanoutput:
  single_record: true
  data_dir: Data/ensembles
  prefix: __ROMS_APP___roms
  exp: ensemble
  type: mean
  date: *date

recentered output:
  single_record: true
  data_dir: Data/ensembles
  prefix: __ROMS_APP___roms
  exp: ensemble
  type: recentered
  date: *date

test:
  reference filename: testref/ens_recenter.ref
  float relative tolerance: 1.0e-3
  log output filename: testoutput/ens_recenter.log
  test output filename: testoutput/ens_recenter.out